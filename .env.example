# Zion — The Powerful AI · Tiffani's Personal Companion
# Built by Christopher Hughes for Tiffani
# Copy this to .env and fill in your values

# ---------- Required ----------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Zion's dedicated Supabase project (DO NOT share with Splendor)
SUPABASE_URL=your_zion_supabase_url_here
SUPABASE_ANON_KEY=your_zion_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_zion_supabase_service_key_here
SUPABASE_JWT_SECRET=your_zion_supabase_jwt_secret_here

# Tiff's owner email (used by requireOwner middleware)
ZION_OWNER_EMAIL=tiffani@example.com

# Locked to Pacific per Tiff's location (Washington State)
ZION_OWNER_TIMEZONE=America/Los_Angeles

# ---------- Optional ----------
# Internet search for legal info retrieval
TAVILY_API_KEY=your_tavily_api_key_here

# Semantic memory (falls back to Supabase-only if missing)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=zion-memory

# Voice fallback (Zion uses OpenAI TTS by default; ElevenLabs optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Multi-AI / response auditing
GROQ_API_KEY=your_groq_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ---------- Governance (dormant for PR 1) ----------
CLASPION_ENABLED=false
CLASPION_FAIL_MODE=block
CLASPION_ACTOR_ID=zion

# ---------- Server ----------
PORT=3000
NODE_ENV=development
